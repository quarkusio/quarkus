<?xml version="1.0" encoding="UTF-8"?>
<project>
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.acme.treeshake</groupId>
        <artifactId>tree-shake-libs-parent</artifactId>
        <version>1.0-SNAPSHOT</version>
    </parent>
    <artifactId>lib-multirelease</artifactId>
    <build>
        <plugins>
            <plugin>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive>
                        <manifestEntries>
                            <Multi-Release>true</Multi-Release>
                        </manifestEntries>
                    </archive>
                </configuration>
            </plugin>
            <plugin>
                <artifactId>maven-compiler-plugin</artifactId>
                <executions>
                    <execution>
                        <id>compile-java-11</id>
                        <phase>compile</phase>
                        <goals><goal>compile</goal></goals>
                        <configuration>
                            <release>11</release>
                            <compileSourceRoots>\${project.basedir}/src/main/java11</compileSourceRoots>
                            <outputDirectory>\${project.build.outputDirectory}/META-INF/versions/11</outputDirectory>
                        </configuration>
                    </execution>
                    <execution>
                        <id>compile-java-99</id>
                        <phase>compile</phase>
                        <goals><goal>compile</goal></goals>
                        <configuration>
                            <compileSourceRoots>\${project.basedir}/src/main/java99</compileSourceRoots>
                            <outputDirectory>\${project.build.outputDirectory}/META-INF/versions/99</outputDirectory>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
